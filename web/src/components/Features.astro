---
import config from '../config/site.json';
const { features } = config;

const featureIcons = {
  terminal: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  highlight: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  clipboard: '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
};
---

<section id="features" class="relative py-24">
  <div class="absolute inset-0 noise-bg"></div>
  <div class="absolute top-1/2 left-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-ax-purple/[0.03] blur-[128px]"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-ax-dark-400/30 bg-ax-dark-800/80 px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-ax-muted">
        Why ax?
      </span>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Everything a Terminal <span class="text-gradient-cyan">Power User</span> Needs
      </h2>
      <p class="mt-4 text-ax-muted">
        No Electron. No GUI bloat. Just a single 23 MB binary that turns your terminal into
        a full-featured API client.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => {
        const isCyan = i % 2 === 0;
        const accent = isCyan ? 'ax-cyan' : 'ax-purple';
        const hoverBorder = isCyan ? 'hover:border-ax-cyan/30 hover:glow-cyan-sm' : 'hover:border-ax-purple/30 hover:glow-purple-sm';
        const gradientFrom = isCyan ? 'from-ax-cyan/5' : 'from-ax-purple/5';

        return (
          <div class={`group relative overflow-hidden rounded-2xl border border-ax-dark-500/50 bg-ax-dark-900 p-6 transition-all duration-300 ${hoverBorder}`}>
            <div class={`pointer-events-none absolute -inset-px rounded-2xl bg-gradient-to-br ${gradientFrom} via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100`}></div>
            <div class="relative">
              <div class={`mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-${accent}/10 ring-1 ring-${accent}/20`}>
                <svg class={`h-6 w-6 text-${accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={featureIcons[feature.icon]}></svg>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-white">{feature.title}</h3>
              <p class="text-sm text-ax-muted/80 leading-relaxed" set:html={feature.description}></p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
