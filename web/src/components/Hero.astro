---
import config from '../config/site.json';
const { hero, github } = config;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background effects -->
  <div class="absolute inset-0 noise-bg"></div>
  <div class="absolute inset-0 grid-pattern"></div>

  <!-- Glowing orbs -->
  <div class="absolute top-1/4 right-1/4 h-96 w-96 rounded-full bg-ax-cyan/5 blur-[128px] animate-glow-pulse"></div>
  <div class="absolute bottom-1/4 left-1/4 h-80 w-80 rounded-full bg-ax-purple/5 blur-[128px] animate-glow-pulse" style="animation-delay: 1.5s"></div>

  <!-- Gradient line at bottom of hero -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-ax-cyan/30 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Pill badge -->
    <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-ax-dark-400/30 bg-ax-dark-800/80 px-4 py-1.5 text-sm text-ax-muted">
      <span class="flex h-2 w-2 rounded-full bg-ax-green-bright"></span>
      <span>{config.site.version} &mdash; {config.site.tagline}</span>
    </div>

    <!-- Headline -->
    <h1 class="mb-6 text-5xl font-extrabold tracking-tight sm:text-6xl md:text-7xl lg:text-8xl">
      <span class="inline-block bg-gradient-to-r from-white via-white to-ax-dark-300 bg-clip-text text-transparent">
        {hero.headline[0]}
      </span>
      <br />
      <span class="inline-block bg-gradient-to-r from-ax-cyan via-ax-cyan to-ax-purple bg-clip-text text-transparent">
        {hero.headline[1]}
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mb-12 max-w-2xl text-lg text-ax-muted sm:text-xl" set:html={hero.subtitle}></p>

    <!-- Install command box -->
    <div class="mx-auto mb-10 max-w-2xl">
      <div class="group relative overflow-hidden rounded-xl border border-ax-dark-500/50 bg-ax-dark-900 transition-all duration-300 hover:border-ax-cyan/30 hover:glow-cyan-sm">
        <!-- Top bar -->
        <div class="flex items-center gap-2 border-b border-ax-dark-600/50 px-4 py-2.5">
          <div class="flex items-center gap-1.5">
            <div class="h-3 w-3 rounded-full bg-ax-red/60"></div>
            <div class="h-3 w-3 rounded-full bg-ax-amber/60"></div>
            <div class="h-3 w-3 rounded-full bg-ax-green/60"></div>
          </div>
          <span class="ml-3 text-xs font-medium text-ax-muted/40">install.sh</span>
        </div>

        <!-- Command content -->
        <div class="flex items-center justify-between px-5 py-4">
          <div class="flex items-center gap-3 overflow-hidden">
            <span class="shrink-0 text-sm font-medium text-ax-cyan">$</span>
            <code class="truncate text-sm font-mono text-white/80 sm:text-base">
              {hero.installCommand}
            </code>
          </div>
          <button
            id="copy-install-btn"
            class="shrink-0 ml-3 flex items-center gap-1.5 rounded-lg border border-ax-cyan/20 bg-ax-cyan/10 px-3.5 py-2 text-xs font-medium text-ax-cyan transition-all hover:bg-ax-cyan/20 hover:border-ax-cyan/40 active:scale-95"
            data-copy={hero.installCommand}
          >
            <svg class="copy-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <span class="copy-text">Copy</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Secondary CTAs -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href={hero.cta.primary.href}
        class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-ax-cyan to-ax-cyan-dim px-6 py-3 text-sm font-semibold text-white transition-all hover:shadow-lg hover:shadow-ax-cyan/20 active:scale-95"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {hero.cta.primary.text}
      </a>
      <a
        href={hero.cta.secondary.href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ax-dark-400/30 bg-ax-dark-800 px-6 py-3 text-sm font-medium text-ax-muted transition-all hover:border-ax-purple/30 hover:text-white active:scale-95"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        {hero.cta.secondary.text}
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (text) {
        try {
          await navigator.clipboard.writeText(text);
          const icon = btn.querySelector('.copy-icon');
          const textEl = btn.querySelector('.copy-text');
          if (icon) {
            icon.innerHTML = '<path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
          }
          if (textEl) textEl.textContent = 'Copied!';
          setTimeout(() => {
            if (icon) {
              icon.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>';
            }
            if (textEl) textEl.textContent = 'Copy';
          }, 2000);
        } catch (e) {
          console.error('Copy failed:', e);
        }
      }
    });
  });
</script>
