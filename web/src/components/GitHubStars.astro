---
export interface Props {
  repo?: string;
}

const { repo = 'zaidejjo/ax' } = Astro.props;
---

<span
  id="github-stars"
  class="flex items-center gap-1 rounded-full bg-ax-dark-600/60 px-2 py-0.5 text-xs text-ax-muted"
  data-repo={repo}
>
  <svg class="h-3 w-3 text-ax-amber" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
  </svg>
  <span id="stars-count">...</span>
</span>
