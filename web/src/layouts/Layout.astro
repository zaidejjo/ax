---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'ax — TUI API Client', description = 'A fast, beautiful terminal-based HTTP client inspired by Postman/Insomnia, powered by Bubble Tea.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-ax-black text-white overflow-x-hidden">
    <slot />
  </body>
</html>
